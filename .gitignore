# Defold editor state and compiled resources
/.editor_settings
/.internal/
/build/

# Defold bundle output (desktop and Android)
/bundle/
/dist/
/dist-*/
/run-android*/
*.apk
*.aab
*.aab.sig
*.aab.orig
build_input_data.json

# Local Android signing credentials
/debug.keystore
/debug.keystore.pass.txt

# Locally downloaded Defold tools
/Defold-x86_64-win32.zip
/tools/Defold/

# Logs and temporary files
*.log
*.tmp
*.bak

# Operating-system files
.DS_Store
Thumbs.db
Desktop.ini

# The fence around the workshop. Raw_Assets/ is the human inbox -- Nicolai
# drops raw art in Grafik/, sound in Lyde/, tracks in Music/ -- and the mills
# in tools/ read from there and write game-ready files into assets/. It is
# 1.9 GB, and nothing raw may enter the repo. Anchored with a leading slash
# so the pattern cannot match at any other depth.
/Raw_Assets/
node_modules/
.expo/
/arkiv/lokalt/
/tools/recordings/
tools/eq-preview.html
tools/rain-preview.html
