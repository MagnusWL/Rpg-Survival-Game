-- The game screen's GUI: top bar, quick-cast bar, HUD bars, everything that
-- floats over the field (hp bars, projectiles, flashes, marks, ground items,
-- floating texts, aim preview, rain and ripples), and the overlays.
local layout = require("game.layout")
local combat = require("game.combat")
local skills = require("game.skills")
local upgrades = require("game.upgrades")
local session = require("game.session")
local effects = require("game.effects")
local settings_overlay = require("main.gui.settings_overlay")
local ui = require("game.ui")
local skill_icon_ui = require("main.gui.skill_icon_ui")
local upgrade_icons = require("main.gui.upgrade_icons")
local inventory = require("game.inventory")
local item_icons = require("main.gui.item_icons")

local W, H = layout.SCREEN_W, layout.SCREEN_H
local PLAY_H = layout.PLAY_H
local BAR_WIDTH = 80

local function gy(sim_y) return layout.to_world_y(sim_y) end

local function atlas_icon(texture, animation, x, y, size)
	local n = gui.new_box_node(vmath.vector3(x, y, 0), vmath.vector3(size, size, 0))
	gui.set_texture(n, texture)
	gui.play_flipbook(n, animation)
	return n
end

-- The HP bar's colour over its own fraction: green at full, sliding through
-- yellow and orange as it drains, red near empty.
local HP_COLOR_STOPS = {
	{ 1.00, { 0.298, 0.686, 0.314 } },
	{ 0.66, { 0.95, 0.85, 0.2 } },
	{ 0.33, { 0.95, 0.55, 0.15 } },
	{ 0.00, { 0.937, 0.196, 0.196 } },
}
local function hp_bar_color(frac)
	frac = math.max(0, math.min(1, frac))
	for i = 1, #HP_COLOR_STOPS - 1 do
		local hi, lo = HP_COLOR_STOPS[i], HP_COLOR_STOPS[i + 1]
		if frac <= hi[1] and frac >= lo[1] then
			local t = (frac - lo[1]) / (hi[1] - lo[1])
			local a, b = lo[2], hi[2]
			return { a[1] + (b[1] - a[1]) * t, a[2] + (b[2] - a[2]) * t, a[3] + (b[3] - a[3]) * t }
		end
	end
	return HP_COLOR_STOPS[#HP_COLOR_STOPS][2]
end

-- The same faces the skill tree wears, on the quick-cast buttons.
local SKILL_ICON = require("main.gui.skilltree_icons")

-- ---- pools ----------------------------------------------------------------

local function make_pool(create)
	return { nodes = {}, create = create }
end

local function pool_sync(pool, list, update_fn)
	local seen = {}
	for _, e in ipairs(list) do
		seen[e.id] = true
		local n = pool.nodes[e.id]
		if not n then
			n = pool.create(e)
			pool.nodes[e.id] = n
		end
		update_fn(n, e)
	end
	for id, n in pairs(pool.nodes) do
		if not seen[id] then
			if type(n) == "table" then
				for _, node in pairs(n) do gui.delete_node(node) end
			else
				gui.delete_node(n)
			end
			pool.nodes[id] = nil
		end
	end
end

-- ---- init ------------------------------------------------------------------

function init(self)
	msg.post(".", "acquire_input_focus")
	self.buttons = {}

	self.aim_cone = ui.box(0, 0, 10, 10, { 1, 0.541, 0.314 }, 0.28)
	gui.set_enabled(self.aim_cone, false)

	-- Floating top controls, with no banner behind them. Next Wave owns the
	-- far-right thumb position, immediately beside the smaller Mobs button.
	local top_y = H - 18
	self.wave_btn = ui.plaque_button(W - 51, top_y, 82, 30)
	self.wave_btn_text = ui.text(W - 51, top_y, "Next Wave", 8, { 0.965, 0.86, 0.6 })
	self.mobstats_btn = ui.plaque_button(W - 128, top_y, 58, 30)
	self.mobstats_text = ui.text(W - 128, top_y, "Mobs", 9, { 0.965, 0.86, 0.6 })
	self.gear_btn = ui.plaque_button(W - 178, top_y, 30, 30)
	self.gear_text = ui.tex_box(W - 178, top_y, 17, 17, "cog")
	self.wave_text = ui.text(W - 235, top_y, "Wave 1", 10, { 1, 1, 1 })

	self.portrait_rim = ui.tex_box(27, top_y, 38, 38, "ring")
	self.portrait_disc = ui.tex_box(27, top_y, 34, 34, "circle")
	self.portrait = gui.new_box_node(vmath.vector3(27, top_y, 0), vmath.vector3(34, 34, 0))
	gui.set_texture(self.portrait, "knight_idle")
	gui.play_flipbook(self.portrait, "f0")
	self.tech_text = ui.text(W - 10, layout.PLAY_TOP - 12, "", 9, { 0.6, 1, 0.6 }, gui.PIVOT_E)

	-- Upgrades sits in the top row immediately after health, with the same
	-- 30 px footprint as Settings.
	local upgrade_x = 72
	-- Same skill-face look as an upgrade card (dark disc, light-blue ring),
	-- since this button is the door to the Upgrades screen.
	self.bag_btn = ui.tex_box(upgrade_x, top_y, 30, 30, "ring")
	gui.set_color(self.bag_btn, vmath.vector4(skill_icon_ui.LIGHT_BLUE[1], skill_icon_ui.LIGHT_BLUE[2], skill_icon_ui.LIGHT_BLUE[3], 1))
	self.bag_disc = ui.tex_box(upgrade_x, top_y, 27, 27, "circle")
	gui.set_color(self.bag_disc, vmath.vector4(skill_icon_ui.DISC[1], skill_icon_ui.DISC[2], skill_icon_ui.DISC[3], 1))
	self.bag_icon = ui.tex_box(upgrade_x, top_y, 16, 16, "arrow_up")
	self.bag_badge = ui.text(upgrade_x + 12, top_y + 10, "", 8, { 1, 0.835, 0.31 })
	self.qc_slots = {}
	-- Thumb-friendly landscape fan: all three centres sit on the same radius
	-- from the bottom-right corner, with equal angular spacing and a small gap
	-- between their 56 px touch faces.
	local quick_radius = 128
	for i = 1, 3 do
		local angle = math.rad(18 + (i - 1) * 27)
		local x = quick_radius * math.cos(angle)
		local y = quick_radius * math.sin(angle)
		-- Same circular design as the skill tree and the menu's loadout
		-- preview: dark disc, orange ring, icon on top -- no more per-skill
		-- background colour, one look everywhere a skill's face shows up.
		local icon_ui = skill_icon_ui.build(x, y, 56, 44)
		local cd_text = ui.text(x, y, "", 16, { 1, 1, 1 })
		local label = ui.text(x, y, "", 9, { 0.85, 0.85, 0.9 })
		-- The skill's own rank and kill/wave xp toward the next one.
		local progress = ui.text(x, y, "", 7, { 0.7, 0.9, 1 })
		gui.set_enabled(label, false)
		gui.set_enabled(progress, false)
		self.qc_slots[i] = { icon_ui = icon_ui, cd = cd_text, label = label, progress = progress }
	end

	self.pool_hp = make_pool(function()
		local bg = ui.box(0, 0, 10, 4, { 0, 0, 0 }, 1)
		local fill = ui.box(0, 0, 10, 4, { 0.298, 0.686, 0.314 }, 1)
		gui.set_pivot(fill, gui.PIVOT_W)
		return { bg = bg, fill = fill }
	end)
	self.pool_proj = make_pool(function(e)
		local n = ui.tex_box(0, 0, 8, 8, "circle")
		gui.set_color(n, vmath.vector4(e.color[1], e.color[2], e.color[3], 1))
		return n
	end)
	self.pool_flash = make_pool(function()
		return ui.tex_box(0, 0, 20, 20, "circle")
	end)
	self.pool_explosion = make_pool(function()
		return {
			fill = ui.tex_box(0, 0, 10, 10, "circle"),
			ring = ui.tex_box(0, 0, 10, 10, "ring"),
		}
	end)
	self.pool_mark = make_pool(function(e)
		local n = ui.tex_box(0, 0, 10, 10, "ring")
		gui.set_color(n, vmath.vector4(e.color[1], e.color[2], e.color[3], 1))
		return n
	end)
	self.pool_lightning = make_pool(function()
		return {
			ui.box(0, 0, 10, 3, { 0.55, 0.82, 1.0 }, 1),
			ui.box(0, 0, 10, 3, { 0.72, 0.92, 1.0 }, 1),
			ui.box(0, 0, 10, 3, { 0.92, 0.98, 1.0 }, 1),
		}
	end)
	self.pool_text = make_pool(function(e)
		return ui.text(0, 0, e.text, 11, e.color)
	end)

	-- Rain and ripples, box nodes driven off the clock each frame.
	self.rain_nodes = {}
	for _, d in ipairs(effects.RAIN_STREAKS) do
		local n = ui.box(0, -100, d.width, d.length, effects.RAIN.color, d.opacity)
		self.rain_nodes[#self.rain_nodes + 1] = { node = n, d = d }
	end
	self.ripple_nodes = {}
	for _, r in ipairs(effects.RIPPLES) do
		local n = ui.tex_box(0, 0, 10, 5, "ring")
		gui.set_color(n, vmath.vector4(effects.RIPPLE.color[1], effects.RIPPLE.color[2], effects.RIPPLE.color[3], 0))
		self.ripple_nodes[#self.ripple_nodes + 1] = { node = n, r = r }
	end
	self.clock = 0

	-- Overlays. Every one of these lives on the "overlay" gui layer so it
	-- always draws above the field/HUD -- Defold has no way to reorder nodes
	-- after the fact, and these panels are mostly built once here in init(),
	-- well before the gameplay chrome that would otherwise stack on top.
	self.settings = settings_overlay.build()
	self.overlay_nodes = {} -- rebuilt per overlay open
	self.dragging = nil
	self.tooltip_box = ui.overlay(ui.box(0, 0, 240, 46, { 0, 0, 0 }, 0.9))
	self.tooltip_text = ui.overlay(ui.text(0, 0, "", 10, { 1, 1, 1 }))
	gui.set_line_break(self.tooltip_text, true)
	gui.set_size(self.tooltip_text, vmath.vector3(900, 200, 0))
	gui.set_enabled(self.tooltip_box, false)
	gui.set_enabled(self.tooltip_text, false)

	-- Scrollable ten-row route grid. Nodes and connecting roads are rebuilt
	-- when the route opens; the panel/title remain stable above the viewport.
	self.route_shade = ui.overlay(ui.box(W / 2, H / 2, W, H, { 0, 0, 0 }, 0.82))
	self.route_panel = ui.overlay(ui.plaque_button(W / 2, H / 2, 720, H - 36))
	self.route_title = ui.overlay(ui.text(W / 2, H - 42, "Choose a Map", 18, { 0.94, 0.88, 0.72 }))
	self.route_progress = ui.overlay(ui.text(W / 2, H - 67, "", 10, { 0.65, 0.72, 0.66 }))
	self.route_hint = ui.overlay(ui.text(W / 2, 28, "Drag or use the mouse wheel to scroll", 9, { 0.58, 0.58, 0.55 }))
	self.route_scroll_track = ui.overlay(ui.box(W / 2 + 342, H / 2, 4, H - 150, { 0.18, 0.17, 0.15 }, 0.9))
	self.route_scroll_thumb = ui.overlay(ui.box(W / 2 + 342, H - 105, 8, 70, { 0.72, 0.55, 0.25 }, 1))
	self.route_nodes = { self.route_shade, self.route_panel, self.route_title, self.route_progress,
		self.route_hint, self.route_scroll_track, self.route_scroll_thumb }
	for _, n in ipairs(self.route_nodes) do gui.set_enabled(n, false) end
	self.route_grid_nodes = {}
	self.route_grid_cards = {}
	self.route_grid_signature = nil
	self.route_scroll = 0
	self.route_drag_y = nil

	-- Game over.
	self.go_shade = ui.overlay(ui.box(W / 2, H / 2, W, H, { 0, 0, 0 }, 0.75))
	self.go_text = ui.overlay(ui.text(W / 2, H / 2 + 76, "She's all alone now", 15, { 1, 1, 1 }))
	-- A small constructed treasure chest replaces the plain reward text.
	self.go_chest_body = ui.overlay(ui.button_frame(W / 2, H / 2 - 4, 76, 38, "btn_gold"))
	self.go_chest_lid = ui.overlay(ui.button_frame(W / 2, H / 2 + 19, 84, 18, "btn_gold"))
	self.go_chest_lock = ui.overlay(ui.box(W / 2, H / 2 + 2, 12, 15, { 0.95, 0.76, 0.18 }, 1))
	self.go_respawn_btn = ui.overlay(ui.plaque_button(W / 2 - 120, H / 2 - 60, 220, 44))
	self.go_respawn_text = ui.overlay(ui.text(W / 2 - 120, H / 2 - 60, "Respawn at Start of Map", 11, { 1, 1, 1 }))
	self.go_btn = ui.overlay(ui.plaque_button(W / 2 + 120, H / 2 - 60, 140, 44))
	self.go_btn_text = ui.overlay(ui.text(W / 2 + 120, H / 2 - 60, "Try Again", 13, { 1, 1, 1 }))
	self.reward_open = false
	self.reward_lid_y = H / 2 + 19
	self.reward_shade = ui.overlay(ui.box(W / 2, H / 2, W, H, { 0, 0, 0 }, 0.45))
	local reward_w, reward_h = 620, 230
	self.reward_panel = ui.overlay(ui.plaque_button(W / 2, H / 2, reward_w, reward_h))
	self.reward_grain = ui.grain(W / 2, H / 2, reward_w, reward_h, 0.16, "overlay")
	self.reward_title = ui.overlay(ui.text(W / 2, H / 2 + 78, "Treasure Chest", 17, { 1, 1, 1 }))
	self.reward_coin = ui.overlay(atlas_icon("skilltree", "coin", W / 2 - 82, H / 2 + 28, 20))
	self.reward_gold = ui.overlay(ui.text(W / 2 - 66, H / 2 + 28, "", 18, { 1, 0.835, 0.31 }, gui.PIVOT_W))
	self.reward_sp_glow = ui.overlay(ui.tex_box(W / 2 + 28, H / 2 + 28, 21, 21, "ring"))
