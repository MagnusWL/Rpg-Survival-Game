	self.reward_skill_points = ui.overlay(ui.text(W / 2 + 44, H / 2 + 28, "", 18, { 0.35, 0.78, 1.0 }, gui.PIVOT_W))
	self.reward_item_btn = ui.overlay(ui.box(W / 2, H / 2 - 42, reward_w - 54, 70, { 0.14, 0.105, 0.072 }, 1))
	self.reward_item_icon = ui.overlay(ui.tex_box(W / 2 - reward_w / 2 + 62, H / 2 - 42, 54, 54, "item_weapon"))
